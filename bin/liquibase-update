#!/usr/bin/env bash
# Run Liquibase update on-demand against the gnp-backend schema.
# Usage: liquibase-update [--dry-run]
#
# Creates a one-shot K8s Job using the same Liquibase image and config
# as the Helm hook, without needing migration.enabled=true.
set -euo pipefail

NAMESPACE="gnp"
IMAGE="783147025407.dkr.ecr.us-east-1.amazonaws.com/gnp-backend-liquibase"
TAG="${LIQUIBASE_TAG:-v1.0.1}"
DB_HOST="gnp-timescaledb.gnp.svc.cluster.local"
DB_PORT="5432"
DB_NAME="gnp-prod-db"
DB_SCHEMA="dbgnp_gnp"
DB_USER="gnp_migrate"
SECRET_NAME="gnp-timescaledb-secrets"
SECRET_KEY="GNP_MIGRATE_DB_PASSWORD"
JOB_NAME="liquibase-update-$(date +%s)"

COMMAND="update"
if [[ "${1:-}" == "--dry-run" ]]; then
  COMMAND="update-sql"
  echo "==> Dry run: will print SQL without applying"
fi

echo "==> Creating Liquibase job: $JOB_NAME"
echo "    Image: $IMAGE:$TAG"
echo "    Target: $DB_HOST:$DB_PORT/$DB_NAME (schema: $DB_SCHEMA)"
echo "    Command: liquibase $COMMAND"

kubectl apply -n "$NAMESPACE" -f - <<EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: $JOB_NAME-config
  namespace: $NAMESPACE
data:
  liquibase.properties: |
    changeLogFile=changelog-master.yaml
    url=jdbc:postgresql://$DB_HOST:$DB_PORT/$DB_NAME?currentSchema=$DB_SCHEMA
    username=$DB_USER
    password=\${LIQUIBASE_COMMAND_PASSWORD}
    defaultSchemaName=$DB_SCHEMA
    liquibaseSchemaName=$DB_SCHEMA
    liquibase.hub.mode=off
    liquibase.show-banner=false
---
apiVersion: batch/v1
kind: Job
metadata:
  name: $JOB_NAME
  namespace: $NAMESPACE
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 3600
  template:
    spec:
      restartPolicy: Never
      securityContext:
        runAsUser: 0
        runAsGroup: 0
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: karpenter.sh/nodepool
                    operator: Exists
      volumes:
        - name: config
          configMap:
            name: $JOB_NAME-config
      containers:
        - name: liquibase
          image: "$IMAGE:$TAG"
          workingDir: /liquibase/changelog
          command:
            - liquibase
            - --defaults-file=/liquibase/config/liquibase.properties
            - $COMMAND
          env:
            - name: LIQUIBASE_COMMAND_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: $SECRET_NAME
                  key: $SECRET_KEY
          volumeMounts:
            - name: config
              mountPath: /liquibase/config
              readOnly: true
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
EOF

echo "==> Waiting for job to complete..."
kubectl wait --for=condition=complete --timeout=120s -n "$NAMESPACE" "job/$JOB_NAME" 2>/dev/null || true

echo "==> Logs:"
kubectl logs -n "$NAMESPACE" "job/$JOB_NAME" --tail=50 2>/dev/null || echo "(no logs yet)"

STATUS=$(kubectl get job -n "$NAMESPACE" "$JOB_NAME" -o jsonpath='{.status.conditions[0].type}' 2>/dev/null)
if [[ "$STATUS" == "Complete" ]]; then
  echo "==> Liquibase $COMMAND completed successfully"
  kubectl delete configmap -n "$NAMESPACE" "$JOB_NAME-config" --ignore-not-found
else
  echo "==> Job status: $STATUS (check logs above for errors)"
  echo "    Cleanup: kubectl delete job/$JOB_NAME configmap/$JOB_NAME-config -n $NAMESPACE"
fi
